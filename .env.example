# Скопируй этот файл в .env.local и заполни значениями
# (.env.local не коммитится — он уже в .gitignore)
#
# В Vercel эти же переменные нужно добавить в Project Settings → Environment Variables

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_KEY=your-publishable-or-anon-key

# Имя бота в Telegram (без @) и slug Mini App из BotFather.
# Используются для генерации реферальной ссылки t.me/{bot}/{app}?startapp=ref_X
VITE_BOT_USERNAME=TrainingRPGbot
VITE_APP_NAME=TRPG
